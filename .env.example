# Hosted AI assistant (server-side only — never exposed to the browser).
# Set these on your deployment (e.g. Vercel → Project → Settings → Environment
# Variables) to give every visitor a working assistant via /api/assistant.
# Leave unset for pure local-first development against a local Ollama.

# Enables the proxy. For the default upstream (Ollama cloud), create one at
# https://ollama.com → Settings → API Keys.
ASSISTANT_API_KEY=

# Optional: any Ollama-compatible server to forward to. Default: https://ollama.com
# ASSISTANT_UPSTREAM_URL=https://ollama.com

# Optional: force a model server-side regardless of what clients request.
# ASSISTANT_MODEL=gemma4:31b
